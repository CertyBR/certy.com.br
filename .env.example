# URL base do proxy/API. Aponta para o Cloudflare Worker (proxy) em produção,
# ou para http://localhost:8787 quando usar wrangler dev / bun run dev localmente.
PUBLIC_API_BASE_URL=https://api.certy.com.br

# Endpoint externo de validação de e-mail (Likn).
PUBLIC_EMAIL_VALIDATION_API_URL=https://api.likn.dev/v1/public/email-validation/validate

# Chave pública do Cloudflare Turnstile (exibida no widget do navegador).
# Chave de teste (sempre aprova): 1x00000000000000000000AA
# Obtenha a chave real em https://dash.cloudflare.com/ → Turnstile
PUBLIC_TURNSTILE_SITE_KEY=
